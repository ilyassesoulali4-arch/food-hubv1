# ── FoodHub Auth Server — Environment Variables ──
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=914536200113-91r8gjtnpatjf34uonpqp5t188s7i5a3.apps.googleusercontent.com

# JWT Secret — use a long random string (min 32 chars)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Token expiry (e.g. "7d", "24h", "30d")
JWT_EXPIRES_IN=7d

# Frontend origin allowed to call this backend (no trailing slash)
ALLOWED_ORIGIN=https://food-hubv1.vercel.app

# Server port
PORT=4000
